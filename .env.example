DEBUG=True
DJANGO_SECRET_KEY=change-me
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/team_task_manager
DB_SSL_REQUIRE=False
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
TIME_ZONE=UTC
PORT=8000
WEB_CONCURRENCY=3

# Docker Compose database defaults
POSTGRES_DB=team_task_manager
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

DEV_DASHBOARD_URL=http://127.0.0.1:8101
KNOWLEDGE_SYSTEM_URL=http://127.0.0.1:8102
KNOWLEDGE_BASE_URL=http://127.0.0.1:8103
TASK_MANAGER_URL=http://127.0.0.1:8104
ECOSYSTEM_CURRENT_SERVICE=team_task_manager

# Reverse proxy / HTTPS deployment
SECURE_PROXY_SSL_HEADER=False
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

LOG_LEVEL=INFO
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
